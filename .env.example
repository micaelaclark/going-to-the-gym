# Strava — create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=   # leave blank, run: python sync.py --setup-strava

# Oura — create a token at https://cloud.ouraring.com/personal-access-tokens
OURA_PERSONAL_TOKEN=

# Anthropic — for daily workout recommendations (console.anthropic.com)
ANTHROPIC_API_KEY=
